import os 

def sync_repo(repo_url,local_dir):
    if not os.path.exists(local_dir):
        os.system(f"git clone {repo_url} {local_dir}")
        print(f"cloned {repo_url} into {local_dir}")
    else:
        os.chdir(local_dir)
        os.system('git pull')
        print(f"updated repository in {local_dir}")

