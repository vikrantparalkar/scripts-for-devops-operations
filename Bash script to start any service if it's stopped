#!/bin/bash
SERVICE="#service_name"

if systemctl is-active --quiet $SERVICE; then
    echo "$SERVICE is running."
else
    echo "$SERVICE is down. Starting now..."
    sudo systemctl start $SERVICE
fi


#Suppressing Output 
#(> /dev/null): Redirects the standard output (stdout) of a command so it doesn't print to your screen.Hiding Errors 
#(2> /dev/null): Silences error messages (stderr) generated by a command.
