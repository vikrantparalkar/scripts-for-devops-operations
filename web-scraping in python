import requests
from bs4 import BeautifulSoup

def scrape_headline(url):
    response=requests.get(url)
    storing=BeautifulSoup(response.text, 'html.parser')  #response.text here '.text' will extract the text part from the response
    #response.text is the HTML code of the webpage returned by requests.get() and html.parser turns messy HTML into a parse tree
    headlines=storing.find_all('h2')  #here headlines is plural, used to store multiple data lines & and below we didn't use 's' that means its calling only single item OR you can just use the 'h' as well

    for idx, headline in enumerate(headlines,1): #enumerate gives option to iterate items with no. (deafault=0)
        print(f"{idx}:{headline.text.strip()}") # response.text here '.text' will extract the text part from the response



scrape_headline('') #put any website url in the function
    



